# Terraform state (chứa sensitive data — dùng remote state trên S3 cho production)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Terraform variables (chứa secrets thật — copy từ terraform.tfvars.example)
terraform.tfvars

# Lambda deployment packages (tự build bằng package_lambdas.sh)
lambda/*.zip

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local dev
.terraformrc
terraform.rc

# EFS mount directory (runtime only)
mnt/

# Crash log
crash.log
crash.*.log
