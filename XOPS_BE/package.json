{
  "name": "backend",
  "version": "1.0.0",
  "description": "BE_LMS - MERN + TS Backend",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "build": "echo \"skip typecheck build\"",
    "start": "ts-node --transpile-only -r tsconfig-paths/register src/index.ts",
    "build:prod": "echo \"skip typecheck build\"",
    "start:prod": "ts-node --transpile-only -r tsconfig-paths/register src/index.ts",
    "test": "jest",
    "seed:vouchers": "ts-node --transpile-only -r tsconfig-paths/register src/seeds/voucher.seed.ts",
    "seed:products": "ts-node --transpile-only -r tsconfig-paths/register src/seeds/product.seed.ts",
    "seed:users": "ts-node --transpile-only -r tsconfig-paths/register src/seeds/user.seed.ts",
    "seed:orders": "ts-node --transpile-only -r tsconfig-paths/register src/seeds/order.seed.ts"
  },
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1036.0",
    "@aws-sdk/s3-request-presigner": "^3.1036.0",
    "@google/generative-ai": "^0.24.1",
    "@payos/node": "^2.0.5",
    "axios": "^1.13.6",
    "bcrypt": "^5.1.1",
    "cloudinary": "^1.41.3",
    "cookie": "^1.0.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "groq-sdk": "^0.37.0",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^3.0.1",
    "mongoose": "^8.2.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.22",
    "@types/nodemailer": "^7.0.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
