NODE_ENV=development
PORT=4000

# Frontend URL
APP_ORIGIN=http://localhost:3000

# MongoDB / DocumentDB connection string
# Local dev: mongodb://localhost:27017/foodiedash
# AWS DocDB: mongodb://USER:PASS@your-docdb-cluster.cluster-XXXXXXXX.us-west-2.docdb.amazonaws.com:27017/YOUR_DB?tls=true&tlsCAFile=/app/global-bundle.pem&replicaSet=rs0&retryWrites=false&authMechanism=SCRAM-SHA-1
# NOTE: DocumentDB only supports SCRAM-SHA-1 — must add &authMechanism=SCRAM-SHA-1
# NOTE: Must include database name before '?' (e.g. :27017/foa?) otherwise data is empty
MONGODB_URI=mongodb://localhost:27017/foodiedash

# JWT secrets (generate with: openssl rand -hex 64)
AUTH_JWT_SECRET=your-jwt-secret-min-64-chars
AUTH_JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-64-chars

# Nodemailer — Google App Password
GOOGLE_APP_USER=your-email@gmail.com
GOOGLE_APP_PASSWORD=your-google-app-password

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Groq AI
GROQ_API_KEY=your-groq-api-key

# PayOS payment gateway
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key
